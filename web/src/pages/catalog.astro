---
// src/pages/catalog.astro
// Every byox stage, across every course, in one filterable table. Rendered
// inside Starlight (StarlightPage) so it inherits the site nav, sidebar,
// theme and logo, but widened past the prose column — the table needs the
// room. Row click opens a modal; the detail (full stage description, plus
// the reference solution source when verified) is fetched from
// /catalog-details/<course>-<slug>.json on demand so solutions never load
// with the table.
//
// Data comes from src/data/catalog.ts, generated by `go run .` inside
// web/gen from courses.yml + each course's vendored course-definition.yml.
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import { CATALOG, COURSES } from '../data/catalog';

const total = CATALOG.length;
const verified = CATALOG.filter((e) => e.verified).length;
const nCourses = Object.keys(COURSES).length;
const coursesDone = Object.values(COURSES).filter((c) => c.verified === c.total).length;

const DIFF_LABEL: Record<string, string> = {
  very_easy: 'Very easy',
  easy: 'Easy',
  medium: 'Medium',
  hard: 'Hard',
  very_hard: 'Very hard',
};
const DIFF_ORDER: Record<string, number> = { very_easy: 0, easy: 1, medium: 2, hard: 3, very_hard: 4 };

const countFor = (c: string) => CATALOG.filter((e) => e.course === c).length;
const verifiedCountFor = (c: string) => CATALOG.filter((e) => e.course === c && e.verified).length;

// Course <option> list, registry order (courses.yml order == insertion
// order of the COURSES object, since the generator walks it in order).
const courseSlugs = Object.keys(COURSES);
---
<StarlightPage
  frontmatter={{
    title: 'Catalog',
    description: `Every byox stage in one filterable table — ${total} stages across ${nCourses} courses, ${verified} tester-verified.`,
    tableOfContents: false,
    template: 'doc',
  }}
>
  <p class="cat-intro">
    All {total} stages across {nCourses} courses in one place — filter by course or verification
    status, or search. Click any row for the stage description and, where verified, the worked
    reference solution. Expand a course header for what it teaches.
  </p>

  <ul class="cat-stats" role="list">
    <li><span class="n">{nCourses}</span><span class="l">Courses</span></li>
    <li><span class="n">{coursesDone}</span><span class="l">Fully verified</span></li>
    <li><span class="n">{total}</span><span class="l">Stages</span></li>
    <li><span class="n">{verified}</span><span class="l">✓ Verified</span></li>
  </ul>

  <div class="cat-legend">
    <strong>What "verified" means:</strong>
    <span><b class="mc">✓ Verified</b> — the stage has a reference solution checked in, tested cumulatively against the official CodeCrafters tester.</span>
    <span>Unverified stages either aren't attempted yet, or (BitTorrent 10+) are blocked by something outside this repo — see the course note.</span>
  </div>

  <div class="cat-filters" role="search" aria-label="Filter catalog">
    <div class="fg">
      <span class="fl">Status</span>
      <button class="pill active" data-status="all">All</button>
      <button class="pill" data-status="verified"><span class="pico">✓</span> Verified</button>
      <button class="pill" data-status="unverified">Unverified</button>
    </div>
    <div class="fg">
      <label class="fl" for="courseSel">Course</label>
      <select id="courseSel" aria-label="Filter by course">
        <option value="all">All courses</option>
        {courseSlugs.map((s) => <option value={s}>{COURSES[s].name.replace(/^Build your own /, '')}</option>)}
      </select>
    </div>
    <div class="fg">
      <label class="fl" for="searchBox">Search</label>
      <input id="searchBox" type="search" placeholder="course, stage, description…" autocomplete="off" spellcheck="false" />
    </div>
    <span class="rc" id="rc">{total} of {total}</span>
  </div>

  <div class="cat-tablewrap">
    <table class="cat-table" id="catTable">
      <thead>
        <tr>
          <th style="width:76px">✓</th>
          <th style="width:11rem" class="c-course">Course</th>
          <th style="width:16rem">Stage</th>
          <th style="width:90px">Level</th>
          <th>Description</th>
        </tr>
      </thead>
      <tbody id="catBody">
        {(() => {
          let last = '';
          return CATALOG.flatMap((e, i) => {
            const rows: any[] = [];
            const c = COURSES[e.course];
            if (e.course !== last) {
              last = e.course;
              rows.push(
                <tr class="course-row" data-course={e.course} data-label={c.name} data-learn={c.learn} data-note={c.note}
                    tabindex="0" role="button" aria-expanded="false">
                  <td colspan="5">
                    <span class="tdot" style={`background:${c.color}`}></span>
                    {c.name}
                    <span class="ttier">{verifiedCountFor(e.course)}/{countFor(e.course)} verified</span>
                    <span class="texp">▸</span>
                  </td>
                </tr>
              );
            }
            const slug = `${e.course}-${e.slug}`;
            const search = `${e.course} ${c.name} ${e.title} ${e.difficulty} ${e.description}`.toLowerCase();
            rows.push(
              <tr class="ex-row" data-i={i} data-slug={slug} data-course={e.course}
                  data-verified={e.verified ? '1' : '0'} data-search={search} data-desc={e.description}
                  data-source={e.sourcePath} data-index={e.index} data-title={e.title}
                  tabindex="0" role="button">
                <td><span class={`badge ${e.verified ? 'b-yes' : 'b-no'}`}>{e.verified ? '✓' : '—'}</span></td>
                <td class="c-course"><span class="tchip" style={`background:${c.color}`}>{c.name.replace(/^Build your own /, '')}</span></td>
                <td><span class="slug">{e.index}. {e.title}</span></td>
                <td><span class={`dbadge d-${e.difficulty}`}>{DIFF_LABEL[e.difficulty] ?? e.difficulty}</span></td>
                <td class="dsc">{e.description}<span class="exp">▸</span></td>
              </tr>
            );
            return rows;
          });
        })()}
      </tbody>
    </table>
    <div class="cat-empty" id="catEmpty" hidden>No stages match — clear the search or change filters.</div>
  </div>

  <!-- Floating "what this course teaches" panel. Fixed-positioned so it shows
       even when its course header row is pinned by position:sticky. -->
  <div id="coursePop" class="topic-pop" hidden role="dialog" aria-label="Course details">
    <button class="topic-pop-x" id="coursePopX" aria-label="Close">✕</button>
    <h3 id="coursePopTitle"></h3>
    <p id="coursePopLearn"></p>
    <p id="coursePopNote" class="topic-pop-note" hidden></p>
  </div>

  <dialog id="catModal" class="cat-modal" aria-labelledby="mTitle">
    <article>
      <header>
        <div class="m-meta">
          <span class="badge" id="mBadge"></span>
          <span class="tchip" id="mCourse"></span>
        </div>
        <h2 id="mTitle"></h2>
        <button class="m-close" id="mClose" aria-label="Close">✕</button>
      </header>
      <div class="m-body">
        <p class="m-desc" id="mDesc"></p>
        <div class="m-run">
          <div class="m-run-primary">
            <span class="m-run-l">▶ Run it</span>
            <p class="m-run-steps">From the repo root: <code id="mRunCmd"></code> — or <code>just tui</code> to work through everything in order with instant feedback.</p>
          </div>
        </div>
        <div class="m-links" id="mLinks"></div>
        <div class="m-section" id="mDetailWrap" hidden>
          <h3>The stage</h3>
          <div class="sl-markdown-content m-md" id="mDetail"></div>
        </div>
        <p class="m-loading" id="mLoading" hidden>Loading the stage…</p>
      </div>
      <footer>
        <button id="mPrev">← Previous</button>
        <span class="m-pos" id="mPos"></span>
        <button id="mNext">Next →</button>
      </footer>
    </article>
  </dialog>

  <!-- The table needs more than the 45rem prose column Starlight gives a doc page. -->
  <style is:global>
    :root:has(#catTable) { --sl-content-width: min(94rem, 100%); }
    :root:has(#catTable) .content-panel .sl-container > :not(.sl-markdown-content) { max-width: none; }
  </style>

  <style>
    .cat-intro { color: var(--sl-color-gray-2); }
    .cat-stats { display: flex; flex-wrap: wrap; gap: 0.6rem; list-style: none; padding: 0; margin: 1.25rem 0; }
    .cat-stats li { flex: 1 1 7rem; text-align: center; border: 1px solid var(--sl-color-gray-5);
      border-radius: 0.6rem; padding: 0.7rem 0.5rem; background: var(--sl-color-black); }
    .cat-stats .n { display: block; font-size: 1.7rem; font-weight: 700; line-height: 1;
      color: var(--sl-color-accent-high); font-variant-numeric: tabular-nums; }
    .cat-stats .l { display: block; margin-top: 0.3rem; font-size: 0.75rem; color: var(--sl-color-gray-3); }

    .cat-legend { display: flex; flex-direction: column; gap: 0.25rem; font-size: 0.85rem;
      color: var(--sl-color-gray-2); border-left: 3px solid var(--sl-color-accent);
      padding: 0.6rem 0 0.6rem 0.9rem; margin: 1rem 0 1.5rem; }
    .cat-legend b.mc { color: var(--sl-color-accent-high); }

    .cat-filters { display: flex; flex-wrap: wrap; align-items: center; gap: 0.5rem 1rem;
      padding: 0.7rem 0.85rem; border: 1px solid var(--sl-color-gray-5); border-radius: 0.6rem;
      background: var(--sl-color-black); margin-bottom: 1rem; line-height: 1;
      position: sticky; top: var(--sl-nav-height); z-index: 3; }
    .cat-filters * { margin: 0; }
    .cat-filters .fg { display: flex; align-items: center; gap: 0.35rem; line-height: 1; }
    .cat-filters .fl { display: inline-flex; align-items: center; font-size: 0.72rem;
      text-transform: uppercase; letter-spacing: 0.05em; color: var(--sl-color-gray-3); }
    .pill { display: inline-flex; align-items: center; justify-content: center; gap: 0.3rem;
      height: 1.85rem; line-height: 1; overflow: hidden; cursor: pointer;
      border: 1px solid var(--sl-color-gray-5); background: transparent;
      color: var(--sl-color-gray-2); font: inherit; font-size: 0.78rem;
      padding: 0 0.7rem; border-radius: 999px; transition: all 0.12s; }
    .pill .pico { font-size: 0.82em; line-height: 1; }
    .pill:hover { border-color: var(--sl-color-accent); color: var(--sl-color-white); }
    .pill.active { background: var(--sl-color-accent); border-color: var(--sl-color-accent); color: var(--sl-color-black); font-weight: 600; }
    .cat-filters select, .cat-filters input { font: inherit; font-size: 0.78rem; border: 1px solid var(--sl-color-gray-5);
      background: var(--sl-color-black); color: var(--sl-color-white); border-radius: 0.35rem; padding: 0.22rem 0.45rem; }
    .cat-filters input { min-width: 190px; }
    .cat-filters input:focus, .cat-filters select:focus { outline: none; border-color: var(--sl-color-accent); }
    .rc { margin-left: auto; font-size: 0.75rem; color: var(--sl-color-gray-3); font-variant-numeric: tabular-nums; }

    .cat-tablewrap { position: relative; }
    .cat-table { display: table; overflow: visible;
      width: 100%; border-collapse: collapse; font-size: 0.85rem; }
    .cat-table thead th { text-align: left; font-size: 0.7rem; font-weight: 600; text-transform: uppercase;
      letter-spacing: 0.05em; color: var(--sl-color-gray-3); padding: 0.5rem 0.6rem; white-space: nowrap;
      background: var(--sl-color-bg); border-bottom: 2px solid var(--sl-color-gray-5);
      position: sticky; top: calc(var(--sl-nav-height) + var(--cat-filter-h, 3.5rem)); z-index: 2; }
    .cat-table td { padding: 0.45rem 0.6rem; vertical-align: middle; border-bottom: 1px solid var(--sl-color-hairline, var(--sl-color-gray-6)); }
    .cat-table .ex-row { cursor: pointer; }
    .cat-table .ex-row:hover { background: color-mix(in oklab, var(--sl-color-accent) 6%, transparent); }
    .cat-table .ex-row:focus-visible, .cat-table .course-row:focus-visible { outline: 2px solid var(--sl-color-accent); outline-offset: -2px; }

    .course-row { cursor: pointer; }
    .course-row td { background: var(--sl-color-gray-6); color: var(--sl-color-white); font-weight: 600;
      font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.06em; padding: 0.4rem 0.6rem;
      position: sticky; z-index: 1;
      top: calc(var(--sl-nav-height) + var(--cat-filter-h, 3.5rem) + var(--cat-head-h, 2.2rem)); }
    .course-row:hover td { background: var(--sl-color-gray-5); }
    .tdot { display: inline-block; width: 8px; height: 8px; border-radius: 50%; margin-right: 0.5rem; }
    .ttier { margin-left: 0.6rem; font-weight: 400; color: var(--sl-color-gray-3); text-transform: none; letter-spacing: 0; }
    .texp { float: right; color: var(--sl-color-gray-3); transition: transform 0.12s; }
    .course-row[aria-expanded="true"] .texp { transform: rotate(90deg); color: var(--sl-color-accent-high); }

    .topic-pop { position: fixed; z-index: 5; box-sizing: border-box;
      background: var(--sl-color-bg); border: 1px solid var(--sl-color-accent);
      border-radius: 0.5rem; box-shadow: 0 12px 32px rgb(0 0 0 / 0.4);
      padding: 0.75rem 2.2rem 0.85rem 0.9rem;
      max-height: min(22rem, 55vh); overflow-y: auto; }
    .topic-pop h3 { margin: 0 0 0.35rem; font-size: 0.8rem; text-transform: uppercase;
      letter-spacing: 0.05em; color: var(--sl-color-accent-high); }
    .topic-pop p { margin: 0; font-size: 0.84rem; color: var(--sl-color-gray-1); line-height: 1.6; }
    .topic-pop-note { margin-top: 0.6rem !important; padding-top: 0.6rem; border-top: 1px solid var(--sl-color-gray-6);
      color: #e3b341 !important; }
    .topic-pop code { font-size: 0.78rem; }
    .topic-pop-x { position: absolute; top: 0.5rem; right: 0.6rem; background: none; border: 0;
      color: var(--sl-color-gray-3); font-size: 0.9rem; cursor: pointer; line-height: 1; padding: 0.2rem; }
    .topic-pop-x:hover { color: var(--sl-color-white); }

    .tchip { display: inline-block; font-size: 0.66rem; font-weight: 700; padding: 0.12rem 0.4rem; border-radius: 0.3rem; color: #fff; }
    .slug { font-family: var(--sl-font-mono, monospace); font-size: 0.82rem; color: var(--sl-color-gray-1); }

    .badge { display: inline-block; font-size: 0.8rem; font-weight: 700; width: 1.6rem; text-align: center; border-radius: 999px; }
    .b-yes { background: color-mix(in oklab, var(--sl-color-accent) 22%, transparent); color: var(--sl-color-accent-high); }
    .b-no { background: var(--sl-color-gray-6); color: var(--sl-color-gray-3); }

    .dbadge { display: inline-block; font-size: 0.66rem; font-weight: 600; padding: 0.12rem 0.45rem; border-radius: 999px; }
    .d-very_easy { background: color-mix(in oklab, #4fa86d 25%, transparent); color: #6bcf8e; }
    .d-easy { background: color-mix(in oklab, #3b9eff 22%, transparent); color: #6fb8ff; }
    .d-medium { background: color-mix(in oklab, #d29922 25%, transparent); color: #e3b341; }
    .d-hard { background: color-mix(in oklab, #c53030 25%, transparent); color: #f28b82; }
    .d-very_hard { background: color-mix(in oklab, #9b5de5 28%, transparent); color: #c8a2f0; }

    .dsc { color: var(--sl-color-gray-2); }
    .dsc .exp { float: right; color: var(--sl-color-gray-4); }
    .ex-row:hover .exp { color: var(--sl-color-accent); }

    .cat-empty { text-align: center; padding: 2.5rem 1rem; color: var(--sl-color-gray-3); }

    /* ---- modal ---- */
    .cat-modal { border: 0; padding: 0; background: transparent;
      max-width: min(52rem, 94vw); width: 100%; margin: auto; }
    .cat-modal::backdrop { background: rgb(0 0 0 / 0.7); backdrop-filter: blur(2px); }
    .cat-modal article { display: flex; flex-direction: column; max-height: 88vh;
      background: var(--sl-color-bg); border: 1px solid var(--sl-color-gray-5);
      border-radius: 0.75rem; box-shadow: 0 24px 60px rgb(0 0 0 / 0.45); overflow: hidden; }
    .cat-modal header { position: relative; padding: 1.1rem 3rem 0.9rem 1.4rem;
      border-bottom: 1px solid var(--sl-color-gray-5); background: var(--sl-color-black); }
    .cat-modal .m-meta { display: flex; align-items: center; gap: 0.4rem; margin-bottom: 0.5rem; flex-wrap: wrap; }
    .cat-modal h2 { margin: 0; font-size: 1.1rem; line-height: 1.35; color: var(--sl-color-white); }
    .cat-modal .m-close { position: absolute; top: 0.8rem; right: 0.9rem; background: none; border: 0;
      color: var(--sl-color-gray-3); font-size: 1rem; cursor: pointer; line-height: 1; padding: 0.3rem; border-radius: 0.3rem; }
    .cat-modal .m-close:hover { color: var(--sl-color-white); background: var(--sl-color-gray-6); }

    .cat-modal .m-body { overflow-y: auto; padding: 1.1rem 1.4rem 1.4rem; }
    .cat-modal .m-desc { margin: 0 0 0.8rem; color: var(--sl-color-gray-1); font-size: 0.92rem; line-height: 1.6; }
    .cat-modal .m-run { background: color-mix(in oklab, var(--sl-color-accent) 10%, var(--sl-color-gray-6));
      border: 1px solid color-mix(in oklab, var(--sl-color-accent) 30%, transparent);
      border-radius: 0.4rem; padding: 0.6rem 0.8rem; margin-bottom: 0.8rem; }
    .cat-modal .m-run-l { font-size: 0.82rem; font-weight: 600; color: var(--sl-color-accent-high); }
    .cat-modal .m-run-steps { margin: 0.35rem 0 0; font-size: 0.82rem; color: var(--sl-color-gray-1); line-height: 1.55; }
    .cat-modal .m-run code { font-size: 0.76rem; color: var(--sl-color-white);
      background: var(--sl-color-black); padding: 0.06rem 0.35rem; border-radius: 0.25rem; }
    .cat-modal .m-links { display: flex; flex-wrap: wrap; gap: 0.9rem; font-size: 0.82rem; margin-bottom: 0.4rem; }
    .cat-modal .m-section { margin-top: 1.4rem; border-top: 1px solid var(--sl-color-gray-6); padding-top: 1rem; }
    .cat-modal .m-section h3 { margin: 0 0 0.6rem; font-size: 0.78rem; text-transform: uppercase;
      letter-spacing: 0.06em; color: var(--sl-color-gray-3); }
    .cat-modal .m-md { font-size: 0.88rem; }
    .cat-modal .m-md :global(pre) { font-size: 0.78rem; }
    .cat-modal .m-md :global(details summary) { cursor: pointer; color: var(--sl-color-accent-high); }
    .cat-modal .m-loading { color: var(--sl-color-gray-3); font-size: 0.82rem; margin: 1rem 0 0; }

    .cat-modal footer { display: flex; align-items: center; justify-content: space-between; gap: 0.5rem;
      padding: 0.6rem 1.4rem; border-top: 1px solid var(--sl-color-gray-5); background: var(--sl-color-black); }
    .cat-modal footer button { background: none; border: 1px solid var(--sl-color-gray-5); color: var(--sl-color-gray-2);
      font: inherit; font-size: 0.78rem; padding: 0.2rem 0.7rem; border-radius: 0.35rem; cursor: pointer; }
    .cat-modal footer button:hover:not(:disabled) { border-color: var(--sl-color-accent); color: var(--sl-color-white); }
    .cat-modal footer button:disabled { opacity: 0.35; cursor: default; }
    .cat-modal .m-pos { font-size: 0.72rem; color: var(--sl-color-gray-3); font-variant-numeric: tabular-nums; }

    @media (max-width: 640px) {
      .c-course { display: none; }
      .cat-filters input { min-width: 130px; }
      .cat-modal article { max-height: 92vh; }
      .cat-table { font-size: 0.8rem; table-layout: auto; }
      .cat-table thead th[style] { width: auto !important; }
      .slug { word-break: break-word; }
      .dsc .exp { display: none; }
    }
  </style>

  <script>
    const body = document.getElementById('catBody')!;
    const rc = document.getElementById('rc')!;
    const empty = document.getElementById('catEmpty')!;
    const filters = document.querySelector<HTMLElement>('.cat-filters')!;
    const search = document.getElementById('searchBox') as HTMLInputElement;
    const courseSel = document.getElementById('courseSel') as HTMLSelectElement;
    const statusPills = document.querySelectorAll<HTMLButtonElement>('.pill[data-status]');
    const exRows = Array.from(body.querySelectorAll<HTMLTableRowElement>('tr.ex-row'));
    const courseRows = Array.from(body.querySelectorAll<HTMLTableRowElement>('tr.course-row'));
    const total = exRows.length;
    let status = 'all';

    const thead = document.querySelector<HTMLElement>('.cat-table thead')!;
    const syncFilterHeight = () => {
      const root = document.documentElement.style;
      root.setProperty('--cat-filter-h', `${filters.getBoundingClientRect().height}px`);
      root.setProperty('--cat-head-h', `${thead.getBoundingClientRect().height}px`);
    };
    syncFilterHeight();
    new ResizeObserver(syncFilterHeight).observe(filters);
    new ResizeObserver(syncFilterHeight).observe(thead);

    function apply() {
      const q = search.value.toLowerCase().trim();
      const course = courseSel.value;
      let shown = 0;
      exRows.forEach((row) => {
        const statusOk = status === 'all' || (status === 'verified' ? row.dataset.verified === '1' : row.dataset.verified === '0');
        const courseOk = course === 'all' || row.dataset.course === course;
        const qOk = !q || (row.dataset.search || '').includes(q);
        const ok = statusOk && courseOk && qOk;
        row.hidden = !ok;
        if (ok) shown++;
      });
      courseRows.forEach((tr) => {
        const c = tr.dataset.course;
        const any = exRows.some((r) => r.dataset.course === c && !r.hidden);
        tr.hidden = !any;
        if (!any && tr.getAttribute('aria-expanded') === 'true') closeCoursePop();
      });
      rc.textContent = `${shown} of ${total}`;
      empty.hidden = shown !== 0;
    }

    // ---- course narrative popover ----
    const coursePop = document.getElementById('coursePop')!;
    const coursePopTitle = document.getElementById('coursePopTitle')!;
    const coursePopLearn = document.getElementById('coursePopLearn')!;
    const coursePopNote = document.getElementById('coursePopNote')!;
    let coursePopOwner: HTMLTableRowElement | null = null;

    function positionCoursePop(tr: HTMLTableRowElement) {
      const cell = tr.querySelector('td') ?? tr;
      const r = cell.getBoundingClientRect();
      coursePop.style.top = `${r.bottom + 4}px`;
      coursePop.style.left = `${r.left}px`;
      coursePop.style.width = `${r.width}px`;
    }
    function closeCoursePop() {
      coursePop.hidden = true;
      if (coursePopOwner) coursePopOwner.setAttribute('aria-expanded', 'false');
      coursePopOwner = null;
    }
    function openCoursePop(tr: HTMLTableRowElement) {
      coursePopTitle.textContent = tr.dataset.label || '';
      coursePopLearn.innerHTML = tr.dataset.learn ? `<b>You learn:</b> ${tr.dataset.learn}` : 'No course notes yet.';
      if (tr.dataset.note) {
        coursePopNote.textContent = tr.dataset.note;
        coursePopNote.hidden = false;
      } else {
        coursePopNote.hidden = true;
      }
      positionCoursePop(tr);
      coursePop.hidden = false;
      coursePopOwner = tr;
      tr.setAttribute('aria-expanded', 'true');
    }
    courseRows.forEach((tr) => {
      const toggle = () => (coursePopOwner === tr ? closeCoursePop() : openCoursePop(tr));
      tr.addEventListener('click', toggle);
      tr.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); toggle(); }
      });
    });
    document.getElementById('coursePopX')!.addEventListener('click', closeCoursePop);
    window.addEventListener('scroll', () => { if (coursePopOwner) positionCoursePop(coursePopOwner); }, { passive: true });
    window.addEventListener('resize', () => { if (coursePopOwner) positionCoursePop(coursePopOwner); });
    document.addEventListener('click', (e) => {
      if (!coursePopOwner) return;
      const t = e.target as Node;
      if (!coursePop.contains(t) && !coursePopOwner.contains(t)) closeCoursePop();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && coursePopOwner) closeCoursePop();
    });

    // ---- modal ----
    const modal = document.getElementById('catModal') as HTMLDialogElement;
    const mBadge = document.getElementById('mBadge')!;
    const mCourse = document.getElementById('mCourse')!;
    const mTitle = document.getElementById('mTitle')!;
    const mDesc = document.getElementById('mDesc')!;
    const mRunCmd = document.getElementById('mRunCmd')!;
    const mLinks = document.getElementById('mLinks')!;
    const mDetailWrap = document.getElementById('mDetailWrap')!;
    const mDetail = document.getElementById('mDetail')!;
    const mLoading = document.getElementById('mLoading')!;
    const mPrev = document.getElementById('mPrev') as HTMLButtonElement;
    const mNext = document.getElementById('mNext') as HTMLButtonElement;
    const mPos = document.getElementById('mPos')!;
    const mBody = modal.querySelector<HTMLElement>('.m-body')!;

    const REPO_BLOB = 'https://github.com/madhank93/build-your-own-x/blob/main';
    const cache = new Map<string, any>();
    let current: HTMLTableRowElement | null = null;

    const visibleRows = () => exRows.filter((r) => !r.hidden);

    async function loadDetail(slug: string) {
      if (cache.has(slug)) return cache.get(slug);
      const res = await fetch(`/catalog-details/${slug}.json`);
      if (!res.ok) throw new Error(`${res.status}`);
      const data = await res.json();
      cache.set(slug, data);
      return data;
    }

    async function openRow(row: HTMLTableRowElement, push = true) {
      current = row;
      const d = row.dataset;
      const slug = d.slug!;
      const courseColor = (row.querySelector('.tchip') as HTMLElement)?.style.background || '';
      const verified = d.verified === '1';

      mBadge.className = `badge ${verified ? 'b-yes' : 'b-no'}`;
      mBadge.textContent = verified ? '✓' : '—';
      mCourse.textContent = d.course!;
      mCourse.setAttribute('style', `background:${courseColor}`);
      mTitle.textContent = `${d.index}. ${d.title}`;
      mDesc.textContent = d.desc || '';
      mRunCmd.textContent = `just test ${d.course}`;

      mLinks.innerHTML = '';
      if (verified && d.source) {
        const a = document.createElement('a');
        a.href = `${REPO_BLOB}/${d.source}`;
        a.target = '_blank'; a.rel = 'noopener noreferrer';
        a.textContent = '↗ View the reference solution on GitHub';
        mLinks.append(a);
      }

      mDetailWrap.hidden = true;
      mDetail.innerHTML = '';
      mLoading.hidden = false;
      mLoading.textContent = 'Loading the stage…';
      mBody.scrollTop = 0;

      const idx = visibleRows().indexOf(row);
      mPos.textContent = `${idx + 1} of ${visibleRows().length}`;
      mPrev.disabled = idx <= 0;
      mNext.disabled = idx < 0 || idx >= visibleRows().length - 1;

      if (!modal.open) modal.showModal();
      if (push) {
        const url = new URL(window.location.href);
        url.searchParams.set('stage', slug);
        history.pushState({ stage: slug }, '', url);
      }

      try {
        const data = await loadDetail(slug);
        if (current !== row) return; // a faster click won
        mLoading.hidden = true;
        if (data.detail) {
          mDetail.innerHTML = data.detail;
          mDetailWrap.hidden = false;
        }
      } catch {
        mLoading.textContent = 'Could not load the details for this stage.';
      }
    }

    function step(delta: number) {
      if (!current) return;
      const rows = visibleRows();
      const next = rows[rows.indexOf(current) + delta];
      if (next) openRow(next);
    }

    function closeModal() {
      if (modal.open) modal.close();
    }

    exRows.forEach((row) => {
      row.addEventListener('click', () => openRow(row));
      row.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); openRow(row); }
      });
    });

    document.getElementById('mClose')!.addEventListener('click', closeModal);
    mPrev.addEventListener('click', () => step(-1));
    mNext.addEventListener('click', () => step(1));
    modal.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });
    modal.addEventListener('close', () => {
      if (current) current.focus();
      current = null;
      const url = new URL(window.location.href);
      if (url.searchParams.has('stage')) {
        url.searchParams.delete('stage');
        history.pushState({}, '', url.pathname + url.search);
      }
    });
    modal.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft' && !mPrev.disabled) { e.preventDefault(); step(-1); }
      if (e.key === 'ArrowRight' && !mNext.disabled) { e.preventDefault(); step(1); }
    });

    statusPills.forEach((b) => b.addEventListener('click', () => {
      statusPills.forEach((p) => p.classList.remove('active'));
      b.classList.add('active'); status = b.dataset.status!; apply();
    }));
    courseSel.addEventListener('change', apply);
    search.addEventListener('input', apply);
    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') { e.preventDefault(); search.focus(); search.select(); }
    });

    // Deep links: /catalog/?stage=<course>-<slug> opens straight into the
    // modal; /catalog/?course=<course> preselects the course filter.
    function openFromUrl(push = false) {
      const params = new URL(window.location.href).searchParams;
      const course = params.get('course');
      if (course && [...courseSel.options].some((o) => o.value === course)) {
        courseSel.value = course;
        apply();
      }
      const want = params.get('stage');
      if (!want) { closeModal(); return; }
      const row = exRows.find((r) => r.dataset.slug === want);
      if (row) openRow(row, push);
    }
    window.addEventListener('popstate', () => openFromUrl());
    openFromUrl();
  </script>
</StarlightPage>
